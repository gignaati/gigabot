# =============================================================================
# Giga Bot — Environment Variables
# Powered by Gignaati — https://www.gignaati.com
#
# Copy this file to .env and fill in your values.
# NEVER commit your .env file to version control.
# =============================================================================

# ── App Configuration ─────────────────────────────────────────────────────────
# The public URL where your Giga Bot instance is accessible
# Local dev: use your ngrok URL (e.g., https://abc123.ngrok.io)
# Production: use your domain (e.g., https://gigabot.yourdomain.com)
APP_URL=https://your-app-url.example.com

# App name (shown in UI)
APP_NAME="Giga Bot"

# ── Authentication ────────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
AUTH_SECRET=your-auth-secret-here

# ── GitHub Configuration ──────────────────────────────────────────────────────
GH_OWNER=your-github-username
GH_REPO=my-gigabot

# GitHub Personal Access Token (scoped to your repo)
# Created automatically by the setup wizard
GH_TOKEN=ghp_your-token-here

# GitHub Webhook Secret (for validating webhook payloads)
GH_WEBHOOK_SECRET=your-webhook-secret-here

# ── LLM Configuration (Chat / Event Handler) ─────────────────────────────────
# Provider: anthropic | openai | google
LLM_PROVIDER=anthropic

# API Key for your chosen LLM provider
LLM_API_KEY=your-api-key-here

# Model name (e.g., claude-opus-4-5, gpt-4o, gemini-2.0-flash)
LLM_MODEL=claude-opus-4-5

# ── Agent LLM Configuration (Docker Jobs) ────────────────────────────────────
# Leave empty to use the same settings as the chat LLM
AGENT_LLM_PROVIDER=
AGENT_LLM_API_KEY=
AGENT_LLM_MODEL=

# ── Optional: Telegram Integration ───────────────────────────────────────────
# Get your bot token from @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# ── Optional: Web Search (Brave API) ─────────────────────────────────────────
BRAVE_API_KEY=

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite database path (relative to project root)
DATABASE_URL=./gigabot.db

# ── Gignaati Version Tracking ────────────────────────────────────────────────
GIGABOT_VERSION=1.0.0
